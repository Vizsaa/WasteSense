# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=wastesense_db

# Session Configuration
SESSION_SECRET=wastesense-secret-key-change-in-production-2024

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Testing & Ngrok Configuration
# Set to 'true' to allow many login attempts from the same IP (useful for public/shared IP scenarios)
BYPASS_RATE_LIMIT=false
